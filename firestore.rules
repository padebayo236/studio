rules_version = '2';

/**
 * @fileoverview Firebase Security Rules for AgriPro Manager
 *
 * @description
 * This ruleset implements a Role-Based Access Control (RBAC) model based on
 * a 'role' field in the /users/{userId} document. It ensures data access is
 * controlled based on user roles (admin, manager, worker).
 *
 * @philosophy
 * These rules prioritize security and data integrity by default. They verify
 * a user's role before allowing access to specific data collections. This design
 * relies on `get()` calls to the user's profile document to check their role,
 * which is a common pattern for centralized RBAC. For enhanced performance at
 * scale, consider denormalizing roles or other necessary authorization data
 * directly onto documents.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getRequestingUserData() {
      return getUserData(request.auth.uid);
    }

    function isAdmin() {
      return isSignedIn() && getRequestingUserData().role == 'admin';
    }

    function isManager() {
      return isSignedIn() && getRequestingUserData().role == 'manager';
    }

    function isWorker() {
      return isSignedIn() && getRequestingUserData().role == 'worker';
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if the requesting manager is assigned to the field of the resource
    function isManagerOfField(fieldId) {
      return isManager() && fieldId in getRequestingUserData().assignedFieldIds;
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    // Users can manage their own profile. Admins have full access.
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow list, delete: if isAdmin();
    }

    // Admins and Managers can manage workers. Workers can read profiles.
    match /workers/{workerId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isManager();

      match /performanceSummary/{summaryId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isManager();
      }
    }

    // Admins and Managers can manage fields.
    match /fields/{fieldId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();

      match /fieldStats/{statId} {
        allow write: if isAdmin() || isManager();
      }
    }

    // Managers can manage tasks in their assigned fields. Workers can read tasks assigned to them.
    match /tasks/{taskId} {
      allow read: if isAdmin() || isManagerOfField(resource.data.fieldId) || (isWorker() && request.auth.uid in resource.data.assignedWorkerIds);
      allow create: if isAdmin() || isManagerOfField(request.resource.data.fieldId);
      allow update: if isAdmin() || isManagerOfField(resource.data.fieldId);
      allow delete: if isAdmin();

      match /taskUpdates/{updateId} {
        allow read: if isAdmin() || isManagerOfField(get(/databases/$(database)/documents/tasks/$(taskId)).data.fieldId) || (isWorker() && request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.assignedWorkerIds);
        allow create: if isSignedIn();
      }
    }

    // Workers can create/update their own attendance. Managers can manage attendance for workers in their fields.
    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isManagerOfField(resource.data.fieldId) || (isWorker() && resource.data.workerId == request.auth.uid);
      allow create: if (isWorker() && request.resource.data.workerId == request.auth.uid) || (isAdmin() || isManagerOfField(request.resource.data.fieldId));
      allow update: if (isWorker() && resource.data.workerId == request.auth.uid) || (isAdmin() || isManagerOfField(resource.data.fieldId));
      allow delete: if isAdmin() || isManagerOfField(resource.data.fieldId);
    }

    // Workers can create their own productivity entries. Managers can manage entries in their fields.
    match /productivity/{productivityId} {
      allow read: if isAdmin() || isManagerOfField(resource.data.fieldId) || (isWorker() && resource.data.workerId == request.auth.uid);
      allow create: if (isWorker() && request.resource.data.workerId == request.auth.uid) || (isAdmin() || isManagerOfField(request.resource.data.fieldId));
      allow update: if (isWorker() && resource.data.workerId == request.auth.uid) || (isAdmin() || isManagerOfField(resource.data.fieldId));
      allow delete: if isAdmin() || isManagerOfField(resource.data.fieldId);
    }

    // Payroll is sensitive. Managed by Admins. Readable by relevant worker/manager.
    match /payroll/{payrollId} {
      allow read: if isAdmin() || isManager() || (isWorker() && resource.data.workerId == request.auth.uid);
      allow write: if isAdmin();

      match /paymentBreakdown/{breakdownId} {
        allow read: if isAdmin() || isManager() || (isWorker() && get(/databases/$(database)/documents/payroll/$(payrollId)).data.workerId == request.auth.uid);
        allow write: if isAdmin();
      }
    }

    // Reports managed by Admins and Managers.
    match /reports/{reportId} {
      allow read, write: if isAdmin() || isManager();
    }
  }
}
